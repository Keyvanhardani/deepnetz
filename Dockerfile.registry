FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn huggingface_hub

COPY deepnetz/__init__.py deepnetz/__init__.py
COPY deepnetz/registry/ deepnetz/registry/

RUN mkdir -p /data

EXPOSE 8090

CMD ["uvicorn", "deepnetz.registry.server:app", "--host", "0.0.0.0", "--port", "8090"]
